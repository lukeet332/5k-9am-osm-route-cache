# On-disk OSM response cache (re-fetchable; not committed — keeps the repo lean and avoids
# republishing raw trace blobs). The derived courses in routes/ + index.json ARE committed.
.tracecache/
.relcache/
# Cached parkrun event list for report.py (per-country totals); refetched ~weekly, never committed.
.events_cache.json
__pycache__/
*.pyc
# Ban-safety signal written by build_cache.py when OSM throttled us (429s past the breaker).
# The self-chaining workflow reads it to back off; per-run only, never committed.
.throttled
